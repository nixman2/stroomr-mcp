{
  "name": "stroomr-mcp",
  "version": "1.0.0",
  "description": "MCP server for local weather and Nord Pool day-ahead electricity prices",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "stroomr-mcp": "dist/index.js"
  },
  "scripts": {
